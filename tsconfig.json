{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "dist",
    "strict": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "declaration": true,
    "sourceMap": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "rootDir": "src",
    "noFallthroughCasesInSwitch": true,
    "checkJs": true,
    "allowJs": true,
  },
  "include": ["src"],
}
